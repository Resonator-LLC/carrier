From: Resonator <armen@resonator.network>
Subject: [PATCH] contrib/pjproject: resolve --with-gnutls path on macOS

pjproject's aconfigure interprets --with-gnutls=DIR literally as a
prefix, so the upstream `--with-gnutls=yes` ends up trying to
`-Iyes/include`. On Linux the value still works because pkg-config
provides the right flags later, but on macOS (where GnuTLS comes from
Homebrew and isn't on the default include path) the build fails.

This resolves the prefix to `$(brew --prefix gnutls)` on macOS while
leaving the existing literal `yes` in place on Linux. Everything else
in PJPROJECT_OPTIONS is unchanged.

Upstream issue: not yet filed. TODO: open a PR against jami-daemon.

diff --git a/contrib/src/pjproject/rules.mak b/contrib/src/pjproject/rules.mak
index 944aba461..144bebce6 100644
--- a/contrib/src/pjproject/rules.mak
+++ b/contrib/src/pjproject/rules.mak
@@ -21,13 +21,21 @@ PJPROJECT_OPTIONS := --disable-sound        \
                      --disable-v4l2         \
                      --disable-openh264     \
                      --disable-resample     \
-                     --disable-libwebrtc    \
-                     --with-gnutls=yes
+                     --disable-libwebrtc

 PKGS += pjproject

 DEPS_pjproject += gnutls

+# pjproject's aconfigure treats --with-gnutls=DIR literally as a prefix
+# (so --with-gnutls=yes tries -Iyes/include). Resolve to a real path.
+ifdef HAVE_MACOSX
+GNUTLS_PREFIX ?= $(shell brew --prefix gnutls 2>/dev/null)
+PJPROJECT_OPTIONS += --with-gnutls=$(GNUTLS_PREFIX)
+else
+PJPROJECT_OPTIONS += --with-gnutls=yes
+endif
+
 ifdef HAVE_LINUX
 PJPROJECT_OPTIONS += --enable-epoll
 endif
